# DungeonGPT API Keys
# Copy this file to .env and fill in your API keys

# Frontend API base URL (for React app)
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_ENABLE_DEBUG_ROUTES=false
# Legacy global console toggle (kept for compatibility while migrating to logger)
REACT_APP_ENABLE_CONSOLE_LOGS=false
REACT_APP_LOG_LEVEL=debug

# Server config (local dev server only — NOT deployed; production is the CF Worker)
PORT=5000
# Network interface to bind. Defaults to 127.0.0.1 (localhost only). Only set this
# to 0.0.0.0 if you deliberately need LAN access — the CLI task backends spawn
# agentic CLI tools on the host, so do not expose this server publicly.
HOST=127.0.0.1
# Legacy server console toggle (logger now uses LOG_LEVEL)
ENABLE_SERVER_CONSOLE_LOGS=false
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
REQUIRE_API_AUTH=false
API_AUTH_TOKEN=
# CLI task runner limits (src/llm/runner)
CLI_TASK_TIMEOUT_MS=300000
CLI_MAX_CONCURRENT_TASKS=2
CLI_MAX_PROMPT_LENGTH=50000

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for Gemini cloud models, not CLI)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cloudflare Worker URL (for CF Workers AI provider)
# Local dev: http://localhost:8787
# Production: https://your-worker.your-subdomain.workers.dev
REACT_APP_CF_WORKER_URL=http://localhost:8787

# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# CloudFlare Pages production flag (set to 'true' in CF Pages env vars)
REACT_APP_CF_PAGES=false
