# CF Worker local development secrets
# Copy this file to .dev.vars (gitignored) and fill in your values.
# These are used by `wrangler dev` for local testing.
# In production, set these with: wrangler secret put <SECRET_NAME>

# Supabase project URL (e.g. https://abcdefghij.supabase.co)
# Found in: Supabase dashboard > Project Settings > API > Project URL
#
# When set, the worker verifies Supabase JWTs on POST /api/ai/generate.
# Verification uses the JWKS endpoint: ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Supports both RS256 and ES256 (Supabase new JWT Signing Keys).
#
# When absent, auth is skipped (convenient for local dev without Supabase configured).
SUPABASE_URL=https://your-project-ref.supabase.co

# Custom domain (optional)
# If you purchase a custom domain, set it here to allow CORS from that origin.
# Example: https://dungeongpt.com
# Leave empty if using only the default Cloudflare Pages URL.
# CUSTOM_DOMAIN=https://your-custom-domain.com
